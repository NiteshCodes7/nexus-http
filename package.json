{
  "name": "nexus-http",
  "version": "1.0.4",
  "description": "A powerful, feature-rich HTTP client with caching, retries, deduplication, streaming, and more.",
  "main": "src/index.js",
  "types": "src/index.d.ts",
  "exports": {
    ".": {
      "require": "./src/index.js",
      "import": "./src/index.js",
      "types": "./src/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.js --format cjs,esm --dts --clean",
    "test": "node tests/index.test.js"
  },
  "keywords": [
    "http",
    "fetch",
    "client",
    "axios-alternative",
    "request",
    "caching",
    "retry",
    "streaming",
    "deduplication"
  ],
  "author": "Nitesh Ghosh",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/NiteshCodes7/nexus-http"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "tsup": "^8.5.1"
  },
  "dependencies": {
    "typescript": "^6.0.3"
  }
}
