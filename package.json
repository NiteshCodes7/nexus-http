{
  "name": "nexus-http",
  "version": "2.0.0",
  "description": "A powerful, feature-rich HTTP client with caching, retries, deduplication, streaming, and more.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.js --format cjs,esm --dts --clean",
    "test": "node tests/index.test.js"
  },
  "keywords": [
    "http",
    "fetch",
    "client",
    "axios-alternative",
    "request",
    "caching",
    "retry",
    "streaming",
    "deduplication"
  ],
  "author": "Nitesh Ghosh",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/NiteshCodes7/nexus-http"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
